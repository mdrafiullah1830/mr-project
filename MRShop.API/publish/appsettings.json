{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "MongoDB": {
    "ConnectionString": "mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER>.mongodb.net/?retryWrites=true&w=majority",
    "DatabaseName": "mrshop"
  },
  "Jwt": {
    "SecretKey": "<YOUR_32_CHAR_JWT_SECRET_HERE>",
    "Issuer": "MRShopAPI",
    "Audience": "MRShopClient",
    "ExpiresInMinutes": 1440
  }
}
