// SECURITY: Use environment variables for these values in production
{
  "MongoDB": {
    "ConnectionString": "mongodb+srv://YOUR_USER:YOUR_PASS@YOUR_CLUSTER/?appName=cluster0",
    "DatabaseName": "mrshop"
  },
  "Jwt": {
    "SecretKey": "REPLACE_WITH_SECURE_RANDOM_KEY_64_CHARS",
    "Issuer": "MRShopAPI",
    "Audience": "MRShopClient",
    "ExpiresInMinutes": "1440"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
