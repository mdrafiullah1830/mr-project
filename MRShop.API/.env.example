# MRShop.API Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Atlas (required)
MONGODB_CONNECTION_STRING=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DATABASE_NAME=mrshop

# JWT Authentication (required)
JWT_SECRET=your-random-32-char-secret-key-here!!
JWT_ISSUER=MRShopAPI
JWT_AUDIENCE=MRShopClient
JWT_EXPIRES_IN_MINUTES=1440

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:5000
